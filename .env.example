# GABBAR_HUB_PROTOCOL_V7.2 - Environment Variables Template
# --- Supabase Configuration ---
# Your Supabase Project URL (e.g. https://<project-ref>.supabase.co)
VITE_SUPABASE_URL=your_supabase_url

# Your Supabase Anon Key (Legacy JWT or New sb_publishable_* format)
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Security & Service ---
# DO NOT PREFIX SECRET KEYS WITH 'VITE_' to prevent browser exposure.
# SUPABASE_SERVICE_ROLE_KEY=your_secret_key

# Google OAuth (configured in Supabase Dashboard)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google OAuth (configured in Supabase Dashboard)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google OAuth (configured in Supabase Dashboard)
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
